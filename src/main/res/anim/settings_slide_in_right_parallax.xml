<?xml version="1.0" encoding="utf-8"?>
<!-- Underlying screen slides back in from the right when Settings is closed, mirroring the entry. -->
<set xmlns:android="http://schemas.android.com/apk/res/android">
	<translate
		android:duration="320"
		android:fromXDelta="24%"
		android:interpolator="@android:interpolator/fast_out_slow_in"
		android:toXDelta="0%" />
	<alpha
		android:duration="320"
		android:fromAlpha="0.85"
		android:interpolator="@android:interpolator/fast_out_slow_in"
		android:toAlpha="1.0" />
</set>
